# ── Backend ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-6
DATABASE_URL=sqlite:///./hootly.db
ALLOWED_ORIGINS=http://localhost:3000
JWT_SECRET=change-me-to-a-long-random-secret
REFRESH_TOKEN_SECRET=change-me-to-a-different-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password
# Optional: override temp dir for cloned repos
# CLONE_BASE_DIR=/tmp

# ── GitHub OAuth ─────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...
STRIPE_ASSESSMENT_BASIC_PRICE=price_...
STRIPE_ASSESSMENT_FULL_PRICE=price_...
APP_URL=http://localhost:3000

# ── GitHub App ────────────────────────────────────────────
# Create a GitHub App at https://github.com/settings/apps
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ── API Keys / MCP ───────────────────────────────────────
# Generate via Settings > API Keys in the web UI
# Used by the MCP server for authenticated access
# HOOTLY_API_KEY=hk_...

# ── Email (Resend) ──────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@hootlylabs.com

# ── CAPTCHA (Cloudflare Turnstile) ──────────────────────
# Leave unset to skip CAPTCHA in development
# TURNSTILE_SECRET_KEY=0x...

# ── Redis (optional, for distributed rate limiting) ─────
# REDIS_URL=redis://localhost:6379/0

# ── Frontend ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
