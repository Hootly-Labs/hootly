# ── Backend ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
DATABASE_URL=sqlite:///./hootly.db
ALLOWED_ORIGINS=http://localhost:3000
