ADMIN_PASSWORD=choose-a-strong-password
# Optional: override temp dir for cloned repos
# CLONE_BASE_DIR=/tmp

# ── Frontend ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
